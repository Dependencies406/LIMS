rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Company logo
    match /company/logo/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Job equipment attachments
    match /jobs/{jobId}/equipment/{equipmentIndex}/attachments/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Job-level attachments (Notes tab)
    match /jobs/{jobId}/attachments/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Statement of Conformity reference PDF
    match /jobs/{jobId}/service-information/statement-of-conformity/{fileName} {
      allow read, write: if request.auth != null;
    }

    // All other files under a job (catch-all)
    match /jobs/{jobId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Customer files
    match /customers/{customerId}/files/{fileName} {
      allow read, write: if request.auth != null;
    }

    // User avatar (primary path)
    match /users/{userId}/avatar/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // All user files — owner only
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Avatar files (alternative path)
    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Report templates
    match /report_templates/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // PDF templates
    match /templates/{templateId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Lab equipment control documents
    match /equipmentControl/{equipmentId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Staff personnel documents
    match /staff/{staffUid}/documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
