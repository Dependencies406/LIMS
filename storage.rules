rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function getUserRole() {
      return request.auth != null
        ? get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    
    // Allow authenticated users to upload and manage company logos
    match /company/logo/{fileName} {
      // Allow read for authenticated users (for displaying logo)
      allow read: if request.auth != null;
      // Allow write (create, update, delete) for authenticated users
      allow write: if request.auth != null;
    }
    
    // Allow authenticated users to manage all job-related files (for deletion operations)
    // This wildcard rule should come AFTER specific rules to allow more specific rules to match first
    // But since Storage rules evaluate in order and first match wins, we put it last
    // Specific rules for attachments come before this to ensure they're handled correctly
    match /jobs/{jobId}/equipment/{equipmentIndex}/attachments/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /jobs/{jobId}/attachments/{fileName} {
      allow read, write: if request.auth != null;
    }
    
    // Statement of Conformity reference PDF (Job → Service Information; see fileUploadService.uploadStatementOfConformityReferencePdf)
    match /jobs/{jobId}/service-information/statement-of-conformity/{fileName} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to manage all other job-related files (for deletion operations)
    // This matches any path under jobs/{jobId}/ that doesn't match the more specific rules above
    match /jobs/{jobId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /customers/{customerId}/files/{fileName} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/avatar/{fileName} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        getUserRole() == 'admin'
      );
    }
    
    // User files - users can read/write their own files; admins can manage for cleanup
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        getUserRole() == 'admin'
      );
    }
    
    // Avatar files (alternative path structure)
    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        getUserRole() == 'admin'
      );
    }
    
    match /report_templates/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /templates/{templateId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Lab equipment control documents (verification forms, certificates, spec sheets, etc.)
    match /equipmentControl/{equipmentId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Staff personnel documents (code of conduct, job description, certificates, etc.)
    match /staff/{staffUid}/documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default rule: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
