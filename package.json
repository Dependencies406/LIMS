{
  "name": "lims-desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm:dev\" \"npm:electron:watch\"",
    "electron:watch": "wait-on http://localhost:3000 && ts-node -T electron/main.ts",
    "electron": "ts-node -T electron/main.ts",
    "build": "npm run build:web && tsc -p electron/tsconfig.json && electron-builder",
    "pack": "electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "@handsontable/react": "^12.2.0",
    "@trebco/treb": "^38.6.2",
    "@types/jszip": "^3.4.0",
    "dompurify": "^3.4.5",
    "exceljs": "^4.4.0",
    "firebase": "^9.22.1",
    "grapheme-splitter": "^1.0.4",
    "handsontable": "^12.2.0",
    "hot-formula-parser": "^4.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "linebreak": "^1.1.0",
    "lz-string": "^1.5.0",
    "mammoth": "^1.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "uuid": "^9.0.0",
    "zod": "^4.4.3",
    "zustand": "^4.3.7"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/uuid": "^9.0.3",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.0.1",
    "electron": "^25.0.0",
    "electron-builder": "^24.6.0",
    "esbuild": "^0.19.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^7.0.1"
  }
}
